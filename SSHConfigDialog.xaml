<Window x:Class="Rere.SSHConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إعداد الاتصال SSH"
        Width="460" Height="480"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="12" Background="#141416" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.7"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#1A1A1E"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <TextBlock Text="🔑  إعداد الاتصال SSH"
                               Foreground="#F1F5F9" FontFamily="Segoe UI"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Width="28" Height="24"
                            HorizontalAlignment="Right"
                            Background="Transparent" BorderBrush="Transparent"
                            Foreground="#64748B" FontSize="12"
                            Cursor="Hand" Click="BtnCancel_Click"/>
                </Grid>
            </Border>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16,20,8">

                    <!-- Host -->
                    <TextBlock Text="الخادم (Host)" Foreground="#94A3B8"
                               FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxHost" Height="34"
                             Background="#1A1A1E" Foreground="#F1F5F9"
                             BorderBrush="#2A2A2E" BorderThickness="1"
                             Padding="10,6" FontFamily="Consolas" FontSize="12"
                             CaretBrush="#F1F5F9">
                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6">
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                </Border>
                            </ControlTemplate>
                        </TextBox.Template>
                    </TextBox>

                    <!-- Port + Username -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Port" Foreground="#94A3B8" FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxPort" Height="34" Text="22"
                                     Background="#1A1A1E" Foreground="#F1F5F9"
                                     BorderBrush="#2A2A2E" BorderThickness="1"
                                     Padding="10,6" FontFamily="Consolas" FontSize="12"
                                     CaretBrush="#F1F5F9" Margin="0,0,8,0">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="اسم المستخدم" Foreground="#94A3B8" FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxUsername" Height="34"
                                     Background="#1A1A1E" Foreground="#F1F5F9"
                                     BorderBrush="#2A2A2E" BorderThickness="1"
                                     Padding="10,6" FontFamily="Segoe UI" FontSize="12"
                                     CaretBrush="#F1F5F9">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <!-- Auth type -->
                    <TextBlock Text="طريقة المصادقة" Foreground="#94A3B8"
                               FontFamily="Segoe UI" FontSize="11" Margin="0,14,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="RbPassword" Content="كلمة مرور"
                                     Foreground="#F1F5F9" FontFamily="Segoe UI"
                                     IsChecked="True" Margin="0,0,20,0"
                                     Checked="AuthType_Changed"/>
                        <RadioButton x:Name="RbPrivateKey" Content="مفتاح خاص"
                                     Foreground="#F1F5F9" FontFamily="Segoe UI"
                                     Checked="AuthType_Changed"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel x:Name="PanelPassword" Margin="0,10,0,0">
                        <TextBlock Text="كلمة المرور" Foreground="#94A3B8"
                                   FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="TxPassword" Height="34"
                                     Background="#1A1A1E" Foreground="#F1F5F9"
                                     BorderBrush="#2A2A2E" BorderThickness="1"
                                     Padding="10,6" FontFamily="Segoe UI" FontSize="12">
                            <PasswordBox.Template>
                                <ControlTemplate TargetType="PasswordBox">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </PasswordBox.Template>
                        </PasswordBox>
                    </StackPanel>

                    <!-- Private Key -->
                    <StackPanel x:Name="PanelPrivateKey" Margin="0,10,0,0" Visibility="Collapsed">
                        <TextBlock Text="مسار المفتاح الخاص" Foreground="#94A3B8"
                                   FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxKeyPath" Grid.Column="0" Height="34"
                                     Background="#1A1A1E" Foreground="#F1F5F9"
                                     BorderBrush="#2A2A2E" BorderThickness="1"
                                     Padding="10,6" FontFamily="Consolas" FontSize="12"
                                     CaretBrush="#F1F5F9">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                            <Button Grid.Column="1" Content="تصفح..." Height="34"
                                    Background="#1A3A5F" Foreground="#F1F5F9"
                                    BorderBrush="Transparent" Padding="10,0"
                                    FontFamily="Segoe UI" FontSize="11"
                                    Cursor="Hand" Margin="6,0,0,0"
                                    Click="BtnBrowseKey_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Test result -->
                    <TextBlock x:Name="TxTestResult" Margin="0,12,0,0"
                               FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="#1A1A1E"
                    BorderBrush="#2A2A2E" BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <Button x:Name="BtnTest" Content="اختبار الاتصال"
                            HorizontalAlignment="Left"
                            Background="#1A3A5F" Foreground="#3B82F6"
                            BorderBrush="Transparent" Height="34" Padding="14,0"
                            FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                            Cursor="Hand" Click="BtnTest_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="إلغاء" Height="34" Padding="14,0"
                                Background="#2A2A2E" Foreground="#94A3B8"
                                BorderBrush="Transparent" FontFamily="Segoe UI" FontSize="12"
                                Cursor="Hand" Margin="0,0,8,0" Click="BtnCancel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="اتصال" Height="34" Padding="18,0"
                                Background="#3B82F6" Foreground="White"
                                BorderBrush="Transparent" FontFamily="Segoe UI" FontSize="12"
                                FontWeight="SemiBold" Cursor="Hand" Click="BtnConnect_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
