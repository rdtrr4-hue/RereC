<Window x:Class="Rere.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Rere"
        xmlns:conv="clr-namespace:Rere.Converters"
        Title="Rere" Height="750" Width="1200"
        MinHeight="700" MinWidth="1100"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="BgPrimary">#0D0D0F</Color>
        <Color x:Key="BgSecondary">#141416</Color>
        <Color x:Key="BgCard">#1A1A1E</Color>
        <Color x:Key="BgHover">#222226</Color>
        <Color x:Key="AccentBlue">#3B82F6</Color>
        <Color x:Key="AccentGreen">#22C55E</Color>
        <Color x:Key="AccentRed">#EF4444</Color>
        <Color x:Key="AccentOrange">#F97316</Color>
        <Color x:Key="AccentYellow">#EAB308</Color>
        <Color x:Key="AccentPurple">#A855F7</Color>
        <Color x:Key="TextPrimary">#F1F5F9</Color>
        <Color x:Key="TextSecondary">#94A3B8</Color>
        <Color x:Key="TextMuted">#475569</Color>
        <Color x:Key="Border">#2A2A2E</Color>

        <SolidColorBrush x:Key="BrBgPrimary"    Color="{StaticResource BgPrimary}"/>
        <SolidColorBrush x:Key="BrBgSecondary"  Color="{StaticResource BgSecondary}"/>
        <SolidColorBrush x:Key="BrBgCard"       Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BrBgHover"      Color="{StaticResource BgHover}"/>
        <SolidColorBrush x:Key="BrAccentBlue"   Color="{StaticResource AccentBlue}"/>
        <SolidColorBrush x:Key="BrAccentGreen"  Color="{StaticResource AccentGreen}"/>
        <SolidColorBrush x:Key="BrAccentRed"    Color="{StaticResource AccentRed}"/>
        <SolidColorBrush x:Key="BrAccentOrange" Color="{StaticResource AccentOrange}"/>
        <SolidColorBrush x:Key="BrAccentYellow" Color="{StaticResource AccentYellow}"/>
        <SolidColorBrush x:Key="BrAccentPurple" Color="{StaticResource AccentPurple}"/>
        <SolidColorBrush x:Key="BrTextPrimary"  Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="BrTextSecondary"Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BrTextMuted"    Color="{StaticResource TextMuted}"/>
        <SolidColorBrush x:Key="BrBorder"       Color="{StaticResource Border}"/>

        <!-- Converters -->
        <conv:BoolToConnectColorConverter x:Key="ConnectColorConv"/>
        <conv:BoolToConnectTextConverter  x:Key="ConnectTextConv"/>
        <conv:LogTypeToColorConverter     x:Key="LogColorConv"/>
        <conv:TRXStatusToColorConverter   x:Key="TRXStatusColorConv"/>
        <conv:VerdictToColorConverter     x:Key="VerdictColorConv"/>
        <conv:ToastTypeToColorConverter   x:Key="ToastColorConv"/>
        <conv:NullToVisibilityConverter   x:Key="NullVisConv"/>
        <conv:InverseBoolConverter        x:Key="InvBoolConv"/>
        <conv:ActiveIPToColorConverter    x:Key="ActiveIPColorConv"/>
        <conv:CountdownTextConverter      x:Key="CountdownTextConv"/>

        <!-- Base Styles -->
        <Style x:Key="BaseText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- DataGrid style -->
        <Style x:Key="RereDataGrid" TargetType="DataGrid">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="BorderBrush"          Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="RowBackground"        Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#12FFFFFF"/>
            <Setter Property="Foreground"           Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrBorder}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
            <Setter Property="HeadersVisibility"    Value="Column"/>
            <Setter Property="SelectionMode"        Value="Single"/>
            <Setter Property="SelectionUnit"        Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"  Value="False"/>
            <Setter Property="CanUserAddRows"       Value="False"/>
            <Setter Property="CanUserDeleteRows"    Value="False"/>
            <Setter Property="CanUserResizeRows"    Value="False"/>
            <Setter Property="IsReadOnly"           Value="True"/>
            <Setter Property="FontFamily"           Value="Segoe UI"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="RowHeight"            Value="34"/>
        </Style>

        <Style x:Key="RereColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="{StaticResource BrBgSecondary}"/>
            <Setter Property="Foreground"    Value="{StaticResource BrTextSecondary}"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Padding"       Value="10,6"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height"        Value="32"/>
        </Style>

        <!-- Sidebar button -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderBrush"  Value="Transparent"/>
            <Setter Property="Foreground"   Value="{StaticResource BrTextSecondary}"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Height"       Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrBgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button (Blue) -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"  Value="{StaticResource BrAccentBlue}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="14,7"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#1E3A5F"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button (Red) -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource BrAccentRed}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Green button -->
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource BrAccentGreen}"/>
        </Style>

        <!-- Orange button (TRX) -->
        <Style x:Key="TRXBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource BrAccentOrange}"/>
        </Style>

        <!-- Purple button (Bypass) -->
        <Style x:Key="BypassBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource BrAccentPurple}"/>
        </Style>

        <!-- Input style -->
        <Style x:Key="RereInput" TargetType="TextBox">
            <Setter Property="Background"       Value="{StaticResource BrBgCard}"/>
            <Setter Property="Foreground"       Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,6"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="CaretBrush"       Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="SelectionBrush"   Value="{StaticResource BrAccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BrAccentBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="RereCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource BrBgCard}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="34"/>
        </Style>

        <!-- ScrollBar styles -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="6"/>
        </Style>
    </Window.Resources>

    <!-- Root rounded window -->
    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Background>
            <SolidColorBrush Color="{StaticResource BgPrimary}"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Toast -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="{StaticResource BrBgSecondary}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + Connection status -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                 Fill="{Binding IsConnected, 
                                        Converter={StaticResource ConnectColorConv},
                                        Source={x:Static local:AppState.Shared}}"/>
                        <TextBlock Text="RERE" Foreground="{StaticResource BrTextPrimary}"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxConnectionStatus"
                                   Margin="12,0,0,0" FontSize="11"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="BtnMinimize" Content="─" Width="32" Height="26"
                                Style="{StaticResource SidebarBtn}"
                                Foreground="{StaticResource BrTextSecondary}"
                                Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize" Content="□" Width="32" Height="26"
                                Style="{StaticResource SidebarBtn}"
                                Foreground="{StaticResource BrTextSecondary}"
                                Click="BtnMaximize_Click"/>
                        <Button x:Name="BtnClose" Content="✕" Width="32" Height="26"
                                Style="{StaticResource SidebarBtn}"
                                Foreground="{StaticResource BrTextSecondary}"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>  <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>    <!-- Main -->
                </Grid.ColumnDefinitions>

                <!-- ─── SIDEBAR ──────────────────────────────────────────────── -->
                <Border Grid.Column="0"
                        Background="{StaticResource BrBgSecondary}"
                        BorderBrush="{StaticResource BrBorder}"
                        BorderThickness="0,0,1,0">
                    <StackPanel Margin="8,12,8,12">

                        <!-- Connect/Disconnect -->
                        <Button x:Name="BtnConnect" Height="36" Margin="0,0,0,6"
                                Style="{StaticResource PrimaryBtn}"
                                Click="BtnConnect_Click">
                            <Button.Content>
                                <TextBlock x:Name="TxConnectBtnText"
                                           Text="{Binding IsConnected,
                                                  Converter={StaticResource ConnectTextConv},
                                                  Source={x:Static local:AppState.Shared}}"
                                           FontWeight="SemiBold"/>
                            </Button.Content>
                        </Button>

                        <Separator Background="{StaticResource BrBorder}" Margin="0,8,0,8"/>

                        <!-- Navigation -->
                        <Button x:Name="BtnNavSessions" Content="📡  جلسات WireGuard"
                                Style="{StaticResource SidebarBtn}"
                                Tag="sessions" Click="NavBtn_Click"/>
                        <Button x:Name="BtnNavActivity"  Content="📋  السجل"
                                Style="{StaticResource SidebarBtn}"
                                Tag="activity" Click="NavBtn_Click"/>
                        <Button x:Name="BtnNavTRX"       Content="⚡  طابور TRX"
                                Style="{StaticResource SidebarBtn}"
                                Tag="trx" Click="NavBtn_Click"/>
                        <Button x:Name="BtnNavHistory"   Content="🕐  التاريخ"
                                Style="{StaticResource SidebarBtn}"
                                Tag="history" Click="NavBtn_Click"/>
                        <Button x:Name="BtnNavPlayers"   Content="👥  قاعدة اللاعبين"
                                Style="{StaticResource SidebarBtn}"
                                Tag="players" Click="NavBtn_Click"/>
                        <Button x:Name="BtnNavFilters"   Content="🚫  الفلاتر"
                                Style="{StaticResource SidebarBtn}"
                                Tag="filters" Click="NavBtn_Click"/>
                        <Button x:Name="BtnNavSettings"  Content="⚙️  الإعدادات"
                                Style="{StaticResource SidebarBtn}"
                                Tag="settings" Click="NavBtn_Click"/>

                        <Separator Background="{StaticResource BrBorder}" Margin="0,8,0,8"/>

                        <!-- Server Stats -->
                        <TextBlock Text="الخادم" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextMuted}"
                                   Margin="12,0,0,6"/>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock x:Name="TxHostname" FontSize="11"
                                       Foreground="{StaticResource BrTextSecondary}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="TxUptime" FontSize="10"
                                       Foreground="{StaticResource BrTextMuted}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Potential Host -->
                        <TextBlock Text="المضيف المحتمل" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextMuted}"
                                   Margin="12,12,0,4"/>
                        <TextBlock x:Name="TxPotentialHost"
                                   Text="{Binding PotentialHost, Source={x:Static local:AppState.Shared}}"
                                   FontSize="11" Foreground="{StaticResource BrAccentYellow}"
                                   TextWrapping="Wrap" Margin="12,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ─── CONTENT PAGES ─────────────────────────────────────────── -->
                <Grid Grid.Column="1">

                    <!-- ╔══════════════════════════════════════════════════════╗  -->
                    <!-- ║  SESSIONS PAGE                                       ║  -->
                    <!-- ╚══════════════════════════════════════════════════════╝  -->
                    <Grid x:Name="PageSessions">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="52"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="160"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{StaticResource BrBgSecondary}"
                                BorderBrush="{StaticResource BrBorder}"
                                BorderThickness="0,0,0,1">
                            <Grid Margin="16,0">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrTextPrimary}">
                                    <Run Text="جلسات WireGuard  "/>
                                    <Run x:Name="TxSessionCount"
                                         Foreground="{StaticResource BrAccentBlue}"
                                         FontSize="12"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock Text="المضيف: " FontSize="11"
                                               Foreground="{StaticResource BrTextMuted}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxHostHeader"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrAccentYellow}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Sessions DataGrid -->
                        <DataGrid x:Name="GridSessions" Grid.Row="1"
                                  Style="{StaticResource RereDataGrid}"
                                  ColumnHeaderStyle="{StaticResource RereColumnHeader}"
                                  ItemsSource="{Binding Sessions, Source={x:Static local:AppState.Shared}}"
                                  SelectionChanged="GridSessions_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="العلم" Binding="{Binding Country}" Width="50"
                                                    ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="130"
                                                    ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="55"
                                                    ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="الاسم" Binding="{Binding PlayerName.Name}" Width="140"
                                                    ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="المدينة" Binding="{Binding City}" Width="100"
                                                    ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="ISP" Binding="{Binding Isp}" Width="*"
                                                    ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="دخل" Binding="{Binding JoinTimeStr}" Width="75"
                                                    ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="دخول" Binding="{Binding Reentry}" Width="50"
                                                    ElementStyle="{StaticResource BaseText}"/>
                            </DataGrid.Columns>

                            <!-- Row context menu -->
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="Foreground"  Value="{StaticResource BrTextPrimary}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BrBgHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1A3B82F6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>

                        <!-- Activity Logs (bottom strip) -->
                        <Border Grid.Row="2"
                                Background="{StaticResource BrBgSecondary}"
                                BorderBrush="{StaticResource BrBorder}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorder}"
                                        BorderThickness="0,0,0,1">
                                    <TextBlock Text="السجل" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               VerticalAlignment="Center" Margin="12,0"/>
                                </Border>

                                <DataGrid x:Name="GridLogs" Grid.Row="1"
                                          Style="{StaticResource RereDataGrid}"
                                          ColumnHeaderStyle="{StaticResource RereColumnHeader}"
                                          ItemsSource="{Binding Logs, Source={x:Static local:AppState.Shared}}"
                                          RowHeight="28">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="نوع" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Type}"
                                                               Foreground="{Binding Type, Converter={StaticResource LogColorConv}}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" Margin="8,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="IP"   Binding="{Binding Ip}"   Width="120" ElementStyle="{StaticResource BaseText}"/>
                                        <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="130" ElementStyle="{StaticResource BaseText}"/>
                                        <DataGridTextColumn Header="الدولة" Binding="{Binding Country}" Width="60" ElementStyle="{StaticResource BaseText}"/>
                                        <DataGridTextColumn Header="المدينة" Binding="{Binding City}" Width="100" ElementStyle="{StaticResource BaseText}"/>
                                        <DataGridTextColumn Header="المدة"   Binding="{Binding Stay}" Width="80" ElementStyle="{StaticResource BaseText}"/>
                                        <DataGridTextColumn Header="الوقت"   Binding="{Binding Time}" Width="70" ElementStyle="{StaticResource BaseText}"/>
                                    </DataGrid.Columns>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource BrTextSecondary}"/>
                                        </Style>
                                    </DataGrid.RowStyle>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ╔══════════════════════════════════════════════════════╗  -->
                    <!-- ║  TRX PAGE                                            ║  -->
                    <!-- ╚══════════════════════════════════════════════════════╝  -->
                    <Grid x:Name="PageTRX" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="52"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>

                        <!-- TRX Header -->
                        <Border Grid.Row="0" Background="{StaticResource BrBgSecondary}"
                                BorderBrush="{StaticResource BrBorder}"
                                BorderThickness="0,0,0,1">
                            <Grid Margin="16,0">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrTextPrimary}">
                                    <Run Text="⚡  طابور TRX  "/>
                                    <Run x:Name="TxTRXCount" Foreground="{StaticResource BrAccentOrange}" FontSize="12"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <Button Content="إلغاء الحالي" Style="{StaticResource DangerBtn}"
                                            Height="28" FontSize="11"
                                            Click="BtnCancelCurrentTRX_Click"/>
                                    <Button Content="مسح الطابور" Style="{StaticResource DangerBtn}"
                                            Height="28" FontSize="11" Margin="6,0,0,0"
                                            Click="BtnClearQueue_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Quick Add TRX -->
                        <Border Grid.Row="1" Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorder}"
                                BorderThickness="0,0,0,1" Padding="16,10">
                            <StackPanel>
                                <TextBlock Text="إضافة سريعة" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrTextSecondary}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxTRXIP" Grid.Column="0"
                                             Style="{StaticResource RereInput}"
                                             Height="32" FontFamily="Consolas"
                                             Tag="IP العميل"/>
                                    <TextBox x:Name="TxTRXPort" Grid.Column="1"
                                             Style="{StaticResource RereInput}"
                                             Height="32" Margin="6,0,0,0" Text="6672"/>
                                    <TextBox x:Name="TxTRXName" Grid.Column="2"
                                             Style="{StaticResource RereInput}"
                                             Height="32" Margin="6,0,0,0"
                                             Tag="اسم اللاعب (اختياري)"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="6,0,0,0">
                                        <Button Content="TRX 1" Style="{StaticResource TRXBtn}"
                                                Height="32" Click="BtnAddTRXNormal_Click"/>
                                        <Button Content="TRX 3" Style="{StaticResource PrimaryBtn}"
                                                Height="32" Margin="4,0,0,0" Click="BtnAddTRXManual_Click"/>
                                        <Button Content="⚡ Bypass" Style="{StaticResource BypassBtn}"
                                                Height="32" Margin="4,0,0,0" Click="BtnAddBypass_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- TRX Queue -->
                        <DataGrid x:Name="GridTRX" Grid.Row="2"
                                  Style="{StaticResource RereDataGrid}"
                                  ColumnHeaderStyle="{StaticResource RereColumnHeader}"
                                  ItemsSource="{Binding TrxQueue, Source={x:Static local:AppState.Shared}}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="الحالة" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusLabel}"
                                                       Foreground="{Binding Status, Converter={StaticResource TRXStatusColorConv}}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="IP"   Binding="{Binding Ip}"   Width="130" ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="Port" Binding="{Binding Port}"  Width="55"  ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*"   ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="الطريقة" Binding="{Binding Method}" Width="110" ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTextColumn Header="الوضع" Binding="{Binding Mode}" Width="75" ElementStyle="{StaticResource BaseText}"/>
                                <DataGridTemplateColumn Header="الموجة" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource BrAccentPurple}"
                                                       VerticalAlignment="Center" Margin="8,0">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}/{1} {2}">
                                                        <Binding Path="BypassCurrentWave"/>
                                                        <Binding Path="BypassTotalWaves"/>
                                                        <Binding Path="BypassWaveMethod"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" Width="24" Height="22"
                                                    FontSize="10" Style="{StaticResource DangerBtn}"
                                                    Tag="{Binding Ip}"
                                                    Click="BtnRemoveTRX_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BrBgHover}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>

                        <!-- TRX Log -->
                        <Border Grid.Row="3" Background="{StaticResource BrBgSecondary}"
                                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="سجل TRX" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrTextSecondary}"/>
                                        <!-- Active countdown pill -->
                                        <Border x:Name="PillActiveCountdown"
                                                Background="#1A22C55E" CornerRadius="10"
                                                Padding="10,2" Margin="12,0,0,0"
                                                Visibility="{Binding TrxActiveIP, Converter={StaticResource NullVisConv},
                                                             Source={x:Static local:AppState.Shared}}">
                                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrAccentGreen}">
                                                <Run Text="🟢 "/>
                                                <Run x:Name="TxActiveIPLabel"
                                                     Text="{Binding TrxActiveIP, Source={x:Static local:AppState.Shared}}"/>
                                                <Run Text=" — "/>
                                                <Run x:Name="TxActiveCountdown"
                                                     Text="{Binding TrxActiveCountdown, Source={x:Static local:AppState.Shared}}"/>
                                                <Run Text="s"/>
                                            </TextBlock>
                                        </Border>
                                        <!-- Queue countdown pill -->
                                        <Border Background="#1A3B82F6" CornerRadius="10"
                                                Padding="10,2" Margin="8,0,0,0">
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource BrTextSecondary}">
                                                <Run Text="⏱ "/>
                                                <Run x:Name="TxQueueCountdown"
                                                     Text="{Binding TrxCountdown, Source={x:Static local:AppState.Shared}}"/>
                                                <Run Text="s"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <DataGrid x:Name="GridTRXLog" Grid.Row="1"
                                          Style="{StaticResource RereDataGrid}"
                                          ColumnHeaderStyle="{StaticResource RereColumnHeader}"
                                          ItemsSource="{Binding TrxLog, Source={x:Static local:AppState.Shared}}"
                                          RowHeight="26">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="IP"   Binding="{Binding Ip}"   Width="120" ElementStyle="{StaticResource BaseText}"/>
                                        <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="130" ElementStyle="{StaticResource BaseText}"/>
                                        <DataGridTextColumn Header="الطريقة" Binding="{Binding Method}" Width="110" ElementStyle="{StaticResource BaseText}"/>
                                        <DataGridTextColumn Header="المدة" Binding="{Binding Duration}" Width="55" ElementStyle="{StaticResource BaseText}"/>
                                        <DataGridTemplateColumn Header="النتيجة" Width="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Result}"
                                                               Foreground="{Binding Result, Converter={StaticResource VerdictColorConv}}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" Margin="8,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="الحكم" Width="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding VerdictLabel}"
                                                               Foreground="{Binding Verdict, Converter={StaticResource VerdictColorConv}}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" Margin="8,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="الوقت" Binding="{Binding SentAt}" Width="80" ElementStyle="{StaticResource BaseText}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ╔══════════════════════════════════════════════════════╗  -->
                    <!-- ║  OTHER PAGES (History / Players / Filters / Settings)║  -->
                    <!-- ╚══════════════════════════════════════════════════════╝  -->
                    <ContentControl x:Name="PageContent" Visibility="Collapsed"/>

                </Grid>
            </Grid>

            <!-- ═══ TOAST ════════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Grid.RowSpan="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,16"
                    CornerRadius="8" Padding="16,8"
                    x:Name="ToastBorder"
                    Visibility="{Binding ToastMessage, Converter={StaticResource NullVisConv},
                                 Source={x:Static local:AppState.Shared}}">
                <Border.Background>
                    <SolidColorBrush x:Name="ToastBg" Color="#1A1A1E"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="Black" Opacity="0.5"/>
                </Border.Effect>
                <TextBlock x:Name="TxToast"
                           Text="{Binding ToastMessage, Source={x:Static local:AppState.Shared}}"
                           Foreground="{Binding ToastType, Converter={StaticResource ToastColorConv},
                                        Source={x:Static local:AppState.Shared}}"
                           FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"/>
            </Border>

        </Grid>
    </Border>
</Window>
