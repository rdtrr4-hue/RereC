<Window x:Class="Rere.TRXMethodDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="اختر طريقة TRX"
        Width="380" Height="380"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="12" Background="#141416" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.7"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1A1A1E"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <TextBlock Text="⚡ اختر طريقة الهجوم" Foreground="#F1F5F9"
                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Width="28" HorizontalAlignment="Right"
                            Background="Transparent" BorderBrush="Transparent"
                            Foreground="#64748B" Cursor="Hand" Click="BtnCancel_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="16,12">
                <!-- Method buttons -->
                <Button Tag="BOTNET-GAME"  Click="BtnSelect_Click" Margin="0,0,0,6"
                        Style="{StaticResource {x:Static Member=local:TRXMethodDialog.MethodBtnStyleKey}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎮" FontSize="16" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="BOTNET-GAME" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                            <TextBlock Text="الطريقة الرئيسية — فعّالة ضد الجيمرز" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
                <Button Tag="BOTNET-UDP PPS" Click="BtnSelect_Click" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💥" FontSize="16" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="BOTNET-UDP PPS" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                            <TextBlock Text="UDP عالي الضغط" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
                <Button Tag="BOTNET-GRE" Click="BtnSelect_Click" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔀" FontSize="16" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="BOTNET-GRE" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                            <TextBlock Text="بروتوكول GRE — تجاوز الحماية" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
                <Button Tag="BOTNET-ICMP" Click="BtnSelect_Click" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏓" FontSize="16" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="BOTNET-ICMP" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                            <TextBlock Text="ICMP Flood — فعّال مع الشبكات القديمة" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
                <Button Tag="IPRAND" Click="BtnSelect_Click" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎲" FontSize="16" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="IPRAND" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                            <TextBlock Text="عشوائي — تشويش وتضليل IP" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border Grid.Row="2" Background="#1A1A1E"
                    BorderBrush="#2A2A2E" BorderThickness="0,1,0,0">
                <Button Content="إلغاء" HorizontalAlignment="Center"
                        Background="#2A2A2E" Foreground="#94A3B8"
                        BorderBrush="Transparent" Height="30" Padding="20,0"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
